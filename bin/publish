# To push you must have write access to https://github.com/lauckhart/chip-image.
#
# Use "docker login" command with a "personal access token (classic)" with package:write scope.
#
# Create access token here: https://github.com/settings/tokens/new?scopes=write:packages
#
# See also https://docs.github.com/en/packages/working-with-a-github-packages-registry/working-with-the-container-registry#authenticating-with-a-personal-access-token-classic

source "$(dirname "${BASH_SOURCE[0]}")/config.sh"

docker push $CHIP_IMAGE:latest
