# Display information about the current CHIP image

source "$(dirname "${BASH_SOURCE[0]}")/config.sh"

IMAGE_VERSION=$(docker inspect --format '{{ index .Config.Labels "org.opencontainers.image.version" }}' $CHIP_IMAGE)
IMAGE_CREATED=$(docker inspect --format '{{ .Created }}' $CHIP_IMAGE)
IMAGE_SIZE=$(docker inspect --format '{{ .Size }}' $CHIP_IMAGE)
IMAGE_ARCH=$(docker inspect --format '{{ .Architecture }}' $CHIP_IMAGE)
CHIP_COMMIT=$(docker inspect --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}' $CHIP_IMAGE | cut -c 1-12)

if [ -x /usr/bin/numfmt ]; then
    IMAGE_SIZE=$(numfmt --to=iec <<< "$IMAGE_SIZE")
fi

cat <<-END
{
    "image": {
        "version": "$IMAGE_VERSION",
        "created": "$IMAGE_CREATED",
        "size": "$IMAGE_SIZE",
        "arch": "$IMAGE_ARCH"
    },
    "chip": {
        "commit": "$CHIP_COMMIT"
    }
}
END
