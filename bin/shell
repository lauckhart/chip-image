# Run a shell in a new ephemeral container (if no args) or in a running container (1 arg)

source "$(dirname "${BASH_SOURCE[0]}")/config.sh"

CONTAINER="$1"

if [ -z "$CONTAINER" ]; then
    docker run \
        -it \
        --rm \
        --workdir / \
        --security-opt apparmor:unconfined \
        -v chip-mdns:/run/dbus \
        --platform "$CHIP_PLATFORM" \
        $CHIP_IMAGE \
        "$@"
else
    docker exec \
        -it \
        "chip-$CONTAINER" \
        bash
fi
